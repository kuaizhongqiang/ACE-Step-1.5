# ACE-Step 1.5 统一配置
# 复制此文件为 .env 并根据需要修改

# === Python 引擎 ===
# DiT 模型路径
ACESTEP_CONFIG_PATH=acestep-v15-turbo
# LM 模型路径：acestep-5Hz-lm-0.6B, acestep-5Hz-lm-1.7B, acestep-5Hz-lm-4B
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
# 设备选择：auto, cuda, cpu, xpu
ACESTEP_DEVICE=auto
# LM 后端：vllm (faster) 或 pt (PyTorch native)
ACESTEP_LM_BACKEND=vllm
# Gradio 端口
GRADIO_PORT=7860
# 界面语言：zh, en, ja, he (默认 zh)
LANGUAGE=zh
# LLM 初始化：auto, true, false (默认 auto)
# ACESTEP_INIT_LLM=auto

# === Node.js 服务 ===
SERVER_PORT=3001
FRONT_PORT=3000
NODE_ENV=development
# Gradio API 地址 (Node.js 通过此地址调用引擎)
ACESTEP_API_URL=http://localhost:7860

# === DeepSeek LLM (替代本地 LM 进行文本处理) ===
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# === 数据库 ===
DATABASE_PATH=./data/acestep.db

# === JWT (本地会话) ===
JWT_SECRET=ace-step-local-secret

# === 存储 ===
AUDIO_DIR=./public/audio

# === 前端 URL (用于 OAuth 分享) ===
# FRONTEND_URL=http://localhost:5173
