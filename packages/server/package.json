  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "~5.8.2",
    "@types/express": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.0",
    "@types/jsonwebtoken": "^9.0.0",
